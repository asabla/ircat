# Copy to .env and fill in. Never commit .env.

# --- Production stack ---
IRCAT_VERSION=dev
IRCAT_INITIAL_ADMIN_PASSWORD=change-me
IRCAT_WEBHOOK_SECRET=
POSTGRES_PASSWORD=change-me

# Optional: override the host-side port bindings if defaults clash.
#IRCAT_IRC_PORT=6667
#IRCAT_IRC_TLS_PORT=6697
#IRCAT_DASHBOARD_PORT=8080

# --- Dev stack port overrides ---
# Set these if the defaults collide with something else on the host.
#IRCAT_DEV_IRC_PORT=6667
#IRCAT_DEV_DASHBOARD_PORT=8080
#IRCAT_DEV_POSTGRES_PORT=5432
#IRCAT_DEV_REDIS_PORT=6379
